# SoulClaw Podman environment
# Preferred public-facing copy of the Podman env template.
# Fork-stage note: runtime env vars still use inherited `OPENCLAW_*` names for compatibility.
# This file can be used with:
#   OPENCLAW_PODMAN_ENV=/path/to/soulclaw.podman.env ./scripts/run-openclaw-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
OPENCLAW_PODMAN_GATEWAY_HOST_PORT=18789
OPENCLAW_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
OPENCLAW_GATEWAY_BIND=lan

# Optional: LLM provider API keys
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
